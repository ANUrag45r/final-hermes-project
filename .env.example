# Copy this file to  backend/.env  and fill in your values.
# Anything secret (DB password, API keys, client secrets) lives ONLY here and
# is read through app/core/config.py — never hard-coded anywhere else.

# --- App ---
ENVIRONMENT=dev

# =================================================================
# Structured storage (persistent)
# =================================================================
# SQLite (default): a file on disk — persists across restarts, zero setup.
DATABASE_URL=sqlite:///./governance_brain.db
#
# PostgreSQL (recommended for real persistence / multi-user). Format:
#   postgresql+psycopg2://USER:PASSWORD@HOST:PORT/DBNAME
# Example (matches docker-compose):
# DATABASE_URL=postgresql+psycopg2://gbrain:CHANGE_ME@localhost:5432/governance

# =================================================================
# Vector memory
# =================================================================
# local  : in-process index, rebuilt from the DB on startup (persistent enough)
# qdrant : external vector DB, vectors persist on disk independently
VECTOR_BACKEND=local
VECTOR_DIM=256
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=transcript_chunks

# =================================================================
# Hermes — the only configurable intelligence dependency
# =================================================================
# Provider options: local | hermes_api | hermes_cli | hermes_gateway | openai | ollama
#
# RECOMMENDED: hermes_api — Hermes Agent's built-in OpenAI-compatible API
# server (agentic: its own memory + tools). Enable it in Hermes first:
#     hermes config set API_SERVER_ENABLED true
#     hermes config set API_SERVER_KEY my-secret-key
#     hermes gateway stop ; hermes gateway        (listens on 127.0.0.1:8642)
# Verify: curl http://127.0.0.1:8642/health  ->  {"status":"ok"}
HERMES_PROVIDER=hermes_api
HERMES_BASE_URL=http://127.0.0.1:8642
HERMES_API_KEY=my-secret-key
HERMES_MODEL=hermes-agent
HERMES_AGENTIC=true
HERMES_TIMEOUT_SECONDS=120
# Notes:
#  - HERMES_BASE_URL has NO /v1 suffix; the app appends /v1/chat/completions.
#  - HERMES_API_KEY must equal the API_SERVER_KEY you set in Hermes.
#  - HERMES_AGENTIC=true sends your question straight to Hermes (its own gbrain
#    + composio tools answer it). Set false only for a plain LLM endpoint.

# --- Alternative providers (leave commented unless you switch to them) ---
# CLI (spawns `hermes chat -q "..."` per message):
#   HERMES_PROVIDER=hermes_cli
HERMES_CLI_PATH=hermes
HERMES_CLI_USE_STDIN=false
HERMES_CLI_ARGS=chat -q {prompt}
# Generic HTTP gateway (configurable JSON shape):
HERMES_GATEWAY_URL=http://localhost:8765
HERMES_GATEWAY_PATH=/chat
HERMES_GATEWAY_API_KEY=
HERMES_GATEWAY_MESSAGE_FIELD=message
HERMES_GATEWAY_RESPONSE_FIELD=response

# =================================================================
# Microsoft 365 — Outlook mail + Teams (optional)
# =================================================================
# Create an Azure AD app registration (portal.azure.com -> App registrations).
# Add a client secret, and under API permissions grant APPLICATION permissions
# with admin consent: Mail.Read, Mail.Send (and Chat.ReadWrite for Teams).
# Leave these blank to keep email features off — the app still runs fine.
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
# The mailbox the app reads/sends as (a user principal name / email):
GRAPH_DEFAULT_USER=

# --- Composio (Contact section: Gmail / Outlook / Teams / Calendar) ---
# Get your key from the Composio dashboard. NEVER commit a real key.
# In the dashboard, connect the accounts you want (Gmail, Outlook, Teams).
COMPOSIO_API_KEY=ak_DDqjAhk1qxblD5Xzh745
COMPOSIO_ENTITY_ID=default
# Action slugs are resolved live; override only if your dashboard differs.
# Discover exact names at runtime: GET /comms/actions?app=gmail
COMPOSIO_GMAIL_FETCH=GMAIL_FETCH_EMAILS
COMPOSIO_GMAIL_SEND=GMAIL_SEND_EMAIL
COMPOSIO_GCAL_EVENTS=GOOGLECALENDAR_EVENTS_LIST
COMPOSIO_OUTLOOK_FETCH=OUTLOOK_LIST_MESSAGES
COMPOSIO_OUTLOOK_SEND=OUTLOOK_OUTLOOK_SEND_EMAIL
COMPOSIO_OUTLOOK_EVENTS=OUTLOOK_LIST_EVENTS

# --- gbrain feed folder (for "Save to gbrain" on meetings) ---
# Clicking "Save to gbrain" writes the meeting here as meeting-<ID>.txt and
# Hermes ingests it (put_page) into its store at ~/.gbrain. Default is
# ~/gbrain-feed. On Windows that's C:\Users\<you>\gbrain-feed. Override below
# if your gbrain watches a different folder.
GBRAIN_FEED_DIR=

# --- Generated reports folder (for "Email this report via Hermes") ---
# PDFs are written here so Hermes can attach them. Default: ~/governance-reports.
REPORTS_DIR=
# `hermes send` email target scheme (it uses <platform>:<dest>). Default email:
HERMES_EMAIL_TO_PREFIX=email:

# --- GStack Review Skill ---
# Path to the local GStack repository root containing skill directories (e.g. plan-ceo-review, plan-design-review, etc.)
GSTACK_DIR=

