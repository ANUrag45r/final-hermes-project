# Frontend configuration (Vite). Copy to .env to override defaults.
#
# Where the browser reaches the backend API.
# Default (no .env needed): http://localhost:8000  — works for `npm run dev`,
# `vite preview`, or any static server, since the backend allows CORS from
# any localhost port.
#
# For the Docker / nginx setup (nginx proxies /api -> backend), build with:
#   VITE_API_BASE=/api
#
# For a backend on another machine:
#   VITE_API_BASE=http://your-host:8000
VITE_API_BASE=http://localhost:8000
